# Domain that points to your Ubuntu server (used by Caddy and the frontend)
DOMAIN=app.example.com

# Email used for ACME/Let's Encrypt (recommended)
ACME_EMAIL=admin@example.com

# Database credentials
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app

# Application secrets
JWT_SECRET=replace-with-a-long-random-string

# Comma-separated list of allowed frontend origins (include https://)
CORS_ORIGINS=https://app.example.com
