# Domain that points to your Ubuntu server (used by Caddy and the frontend)
DOMAIN=app.example.com

# Email used for ACME/Let's Encrypt (recommended)
ACME_EMAIL=admin@example.com

# Database credentials
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=app

# Application secrets
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=8h

# Mandatory bootstrap account (created automatically if no SUPER_ADMIN exists)
SUPER_ADMIN_NAME=Platform Super Admin
SUPER_ADMIN_EMAIL=superadmin@example.com
# Must include: 12+ chars, uppercase, lowercase, number, special
SUPER_ADMIN_PASSWORD=Replace-With-A-Very-Strong-Password-123!

# Comma-separated list of allowed frontend origins (include https://)
CORS_ORIGINS=https://app.example.com

# Cloudflare Named Tunnel token (recommended for production).
# Create in Cloudflare Zero Trust > Networks > Tunnels > Create Tunnel.
CLOUDFLARED_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
