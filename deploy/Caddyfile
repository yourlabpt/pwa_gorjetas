{
  # Disable Caddy admin API and rely on automatic HTTPS
  admin off
}

{$DOMAIN} {
  encode zstd gzip

  @api path /api/*

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://{$DOMAIN}; font-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
  }

  handle_path /api/* {
    reverse_proxy app:3001
  }

  handle {
    reverse_proxy app:3000
  }

  log {
    output stdout
    format json
  }
}
